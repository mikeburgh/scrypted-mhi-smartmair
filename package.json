{
  "name": "@scrypted/mhi-smartmair",
  "version": "0.1.0",
  "description": "Scrypted plugin for Mitsubishi Heavy Industries WF-RAC air conditioners (Smart M-Air)",
  "author": "Mike",
  "license": "Apache-2.0",
  "keywords": [
    "scrypted",
    "mhi",
    "mitsubishi",
    "air-conditioner",
    "hvac",
    "smart-m-air",
    "wf-rac"
  ],
  "scripts": {
    "scrypted-setup-project": "scrypted-setup-project",
    "prescrypted-setup-project": "scrypted-package-json",
    "build": "scrypted-webpack",
    "prepublishOnly": "cross-env NODE_ENV=production scrypted-webpack",
    "prescrypted-vscode-launch": "scrypted-webpack",
    "scrypted-vscode-launch": "scrypted-deploy-debug",
    "scrypted-deploy-debug": "scrypted-deploy-debug",
    "scrypted-debug": "scrypted-debug",
    "scrypted-deploy": "scrypted-deploy",
    "debug": "tsx debug-tool.ts",
    "test": "tsx --test src/*.test.ts"
  },
  "scrypted": {
    "name": "MHI Smart M-Air",
    "type": "DeviceProvider",
    "interfaces": [
      "DeviceProvider",
      "Settings"
    ],
    "pluginId": "@scrypted/mhi-smartmair"
  },
  "dependencies": {
    "axios": "^1.7.2"
  },
  "devDependencies": {
    "@scrypted/sdk": "^0.5.29",
    "@types/node": "^22.0.0",
    "cross-env": "^7.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
